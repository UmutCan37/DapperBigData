@model List<DapperBigData.Dtos.MonthlyTargetDtos.ResultMonthlyTargetDto>
@{
    ViewData["Title"] = "Aylık Hedefler";
    string[] months = { "", "Ocak", "Şubat", "Mart", "Nisan", "Mayıs", "Haziran", "Temmuz", "Ağustos", "Eylül", "Ekim", "Kasım", "Aralık" };
}

<div class="page-hdr">
    <div>
        <div class="breadcrumb">Raporlar / <span>Aylık Hedefler</span></div>
        <div class="page-title">Aylık Hedefler</div>
        <div class="page-sub">Toplam @ViewBag.TotalCount kayıt</div>
    </div>
    <div class="hdr-actions">
        <a asp-action="CreateMonthlyTarget" class="btn btn-primary">
            <i class="fas fa-plus"></i> Yeni Hedef
        </a>
    </div>
</div>

<div class="card">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Yıl</th>
                    <th>Ay</th>
                    <th>Ciro Hedefi</th>
                    <th>Sipariş Hedefi</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="font-weight:700">@item.TargetYear</td>
                        <td><span class="badge badge-primary">@months[item.TargetMonth]</span></td>
                        <td style="font-weight:700">@item.RevenueTarget.ToString("N2") ₺</td>
                        <td>@item.OrderTarget.ToString("N0")</td>
                        <td>
                            <div style="display:flex;gap:6px">
                                <a asp-action="MonthlyTargetDetail" asp-route-year="@item.TargetYear" asp-route-month="@item.TargetMonth" class="btn btn-ghost btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="UpdateMonthlyTarget" asp-route-year="@item.TargetYear" asp-route-month="@item.TargetMonth" class="btn btn-ghost btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <a asp-action="DeleteMonthlyTarget" asp-route-year="@item.TargetYear" asp-route-month="@item.TargetMonth" class="btn btn-danger btn-sm"
                                   onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination")
</div>
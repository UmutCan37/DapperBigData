@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-hdr">
    <div>
        <div class="breadcrumb">Ana Menü / <span>Dashboard</span></div>
        <div class="page-title">Sales Dashboard</div>
        <div class="page-sub">Hoş geldiniz, Admin · Son senkronizasyon: 2 dk önce</div>
    </div>
    <div class="hdr-actions">
        <div style="position:relative">
            <button class="btn btn-ghost" onclick="toggleExportMenu()" id="export-btn">
                <i class="fas fa-download"></i> Export
                <i class="fas fa-chevron-down" style="font-size:10px;margin-left:2px"></i>
            </button>
            <div id="export-menu" style="display:none;position:absolute;right:0;top:calc(100% + 6px);background:#fff;border:1.5px solid var(--border);border-radius:12px;padding:8px;min-width:280px;box-shadow:0 8px 24px rgba(0,0,0,.1);z-index:100">
                <div style="font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;padding:4px 8px 8px">Raporları İndir</div>
                <div style="display:flex;flex-direction:column;gap:4px">
                    <div style="display:flex;align-items:center;gap:8px;padding:8px;border-radius:8px;background:var(--bg)">
                        <i class="fas fa-bag-shopping" style="color:var(--primary);width:16px"></i>
                        <span style="font-size:12px;font-weight:600;flex:1">Sipariş Raporu</span>
                        <a asp-controller="Report" asp-action="OrderExcel" class="btn btn-ghost btn-sm" style="padding:4px 10px">
                            <i class="fas fa-file-excel" style="color:#22C55E"></i> Excel
                        </a>
                        <a asp-controller="Report" asp-action="OrderPdf" class="btn btn-ghost btn-sm" style="padding:4px 10px">
                            <i class="fas fa-file-pdf" style="color:#EF4444"></i> PDF
                        </a>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;padding:8px;border-radius:8px;background:var(--bg)">
                        <i class="fas fa-users" style="color:var(--success);width:16px"></i>
                        <span style="font-size:12px;font-weight:600;flex:1">Müşteri Raporu</span>
                        <a asp-controller="Report" asp-action="CustomerExcel" class="btn btn-ghost btn-sm" style="padding:4px 10px">
                            <i class="fas fa-file-excel" style="color:#22C55E"></i> Excel
                        </a>
                        <a asp-controller="Report" asp-action="CustomerPdf" class="btn btn-ghost btn-sm" style="padding:4px 10px">
                            <i class="fas fa-file-pdf" style="color:#EF4444"></i> PDF
                        </a>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;padding:8px;border-radius:8px;background:var(--bg)">
                        <i class="fas fa-box" style="color:var(--warning);width:16px"></i>
                        <span style="font-size:12px;font-weight:600;flex:1">Ürün Raporu</span>
                        <a asp-controller="Report" asp-action="ProductExcel" class="btn btn-ghost btn-sm" style="padding:4px 10px">
                            <i class="fas fa-file-excel" style="color:#22C55E"></i> Excel
                        </a>
                        <a asp-controller="Report" asp-action="ProductPdf" class="btn btn-ghost btn-sm" style="padding:4px 10px">
                            <i class="fas fa-file-pdf" style="color:#EF4444"></i> PDF
                        </a>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;padding:8px;border-radius:8px;background:var(--bg)">
                        <i class="fas fa-tags" style="color:var(--purple);width:16px"></i>
                        <span style="font-size:12px;font-weight:600;flex:1">Kategori Raporu</span>
                        <a asp-controller="Report" asp-action="CategoryExcel" class="btn btn-ghost btn-sm" style="padding:4px 10px">
                            <i class="fas fa-file-excel" style="color:#22C55E"></i> Excel
                        </a>
                        <a asp-controller="Report" asp-action="CategoryPdf" class="btn btn-ghost btn-sm" style="padding:4px 10px">
                            <i class="fas fa-file-pdf" style="color:#EF4444"></i> PDF
                        </a>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;padding:8px;border-radius:8px;background:var(--bg)">
                        <i class="fas fa-map-location-dot" style="color:var(--success);width:16px"></i>
                        <span style="font-size:12px;font-weight:600;flex:1">Şehir Raporu</span>
                        <a asp-controller="Report" asp-action="CityExcel" class="btn btn-ghost btn-sm" style="padding:4px 10px">
                            <i class="fas fa-file-excel" style="color:#22C55E"></i> Excel
                        </a>
                        <a asp-controller="Report" asp-action="CityPdf" class="btn btn-ghost btn-sm" style="padding:4px 10px">
                            <i class="fas fa-file-pdf" style="color:#EF4444"></i> PDF
                        </a>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;padding:8px;border-radius:8px;background:var(--bg)">
                        <i class="fas fa-bullseye" style="color:var(--danger);width:16px"></i>
                        <span style="font-size:12px;font-weight:600;flex:1">Hedef Raporu</span>
                        <a asp-controller="Report" asp-action="MonthlyTargetExcel" class="btn btn-ghost btn-sm" style="padding:4px 10px">
                            <i class="fas fa-file-excel" style="color:#22C55E"></i> Excel
                        </a>
                        <a asp-controller="Report" asp-action="MonthlyTargetPdf" class="btn btn-ghost btn-sm" style="padding:4px 10px">
                            <i class="fas fa-file-pdf" style="color:#EF4444"></i> PDF
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <button class="btn btn-primary"><i class="fas fa-plus"></i> Yeni Satış</button>
    </div>
</div>

@await Component.InvokeAsync("KpiCards")

<div class="row-2" style="margin-top:16px">
    <div class="card">
        <div class="card-hdr">
            <div>
                <div class="card-title">Aylık Ciro Trendi</div>
                <div class="card-sub">Oca – Ara</div>
            </div>
            <div style="display:flex;gap:6px">
                <span class="badge badge-primary">2026</span>
                <span class="badge badge-muted">2025</span>
            </div>
        </div>
        <div class="chart-wrap"><canvas id="chartRevenue"></canvas></div>
    </div>
    <div class="card">
        <div class="card-hdr">
            <div>
                <div class="card-title">Kategori Bazlı Satış</div>
                <div class="card-sub">Ciro payı</div>
            </div>
        </div>
        <div class="chart-wrap" style="height:180px"><canvas id="chartDonut"></canvas></div>
        <div id="donut-legend" style="display:flex;flex-direction:column;gap:6px;margin-top:12px"></div>
    </div>
</div>

<div class="row-2-eq" style="margin-top:16px">
    @await Component.InvokeAsync("TopCities")
    @await Component.InvokeAsync("PaymentMethods")
</div>

<div class="row-bottom" style="margin-top:16px">
    @await Component.InvokeAsync("TopProducts")
    <div style="display:flex;flex-direction:column;gap:16px">
        @await Component.InvokeAsync("RecentOrders")
        @await Component.InvokeAsync("MonthlyTarget")
    </div>
</div>

@await Component.InvokeAsync("CityMap")

@section Scripts {
    <script>
        // Export dropdown
        function toggleExportMenu() {
            const menu = document.getElementById('export-menu');
            menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
        }

        document.addEventListener('click', function(e) {
            const btn = document.getElementById('export-btn');
            const menu = document.getElementById('export-menu');
            if (!btn.contains(e.target) && !menu.contains(e.target)) {
                menu.style.display = 'none';
            }
        });

        const months = ['Oca','Şub','Mar','Nis','May','Haz','Tem','Ağu','Eyl','Eki','Kas','Ara'];
        const rev2025 = @Html.Raw(ViewBag.Revenue2025 ?? "[]");
        const rev2026 = @Html.Raw(ViewBag.Revenue2026 ?? "[]");

        new Chart(document.getElementById('chartRevenue'), {
            type: 'line',
            data: {
                labels: months,
                datasets: [
                    {
                        label: '2026',
                        data: rev2026,
                        borderColor: '#6366F1',
                        backgroundColor: 'rgba(99,102,241,.08)',
                        fill: true, tension: .4,
                        pointRadius: 3, pointBackgroundColor: '#6366F1',
                        borderWidth: 2.5, pointHoverRadius: 6
                    },
                    {
                        label: '2025',
                        data: rev2025,
                        borderColor: '#CBD5E1', backgroundColor: 'transparent',
                        fill: false, tension: .4,
                        pointRadius: 0, borderWidth: 1.5, borderDash: [5,3]
                    }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: ctx => `₺${ctx.raw}K` } }
                },
                scales: {
                    x: { grid: { display: false }, ticks: { font: { size: 10 }, color: '#94A3B8' } },
                    y: { grid: { color: '#F1F5F9', borderDash: [4,4] }, ticks: { font: { size: 10 }, color: '#94A3B8', callback: v => `₺${v}K` } }
                }
            }
        });

        const catColors = ['#6366F1','#22C55E','#F59E0B','#EF4444','#8B5CF6'];
        const catLabels = @Html.Raw(ViewBag.CategoryLabels ?? "[]");
        const catData = @Html.Raw(ViewBag.CategoryData ?? "[]");

        new Chart(document.getElementById('chartDonut'), {
            type: 'doughnut',
            data: {
                labels: catLabels,
                datasets: [{ data: catData, backgroundColor: catColors, borderWidth: 3, borderColor: '#fff', hoverBorderWidth: 4 }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: ctx => `${ctx.label}: ₺${ctx.raw?.toLocaleString()}` } }
                },
                cutout: '68%'
            }
        });

        const legend = document.getElementById('donut-legend');
        catLabels.forEach((label, i) => {
            legend.innerHTML += `<div style="display:flex;align-items:center;gap:7px">
                <span style="width:9px;height:9px;border-radius:50%;background:${catColors[i]};flex-shrink:0"></span>
                <span style="font-size:11px;color:var(--muted)">${label}</span>
                <span style="margin-left:auto;font-size:11.5px;font-weight:700">₺${Number(catData[i]).toLocaleString()}</span>
            </div>`;
        });

        const pmColors = ['#6366F1','#22C55E','#F59E0B','#EF4444'];
        const pmLabels = @Html.Raw(ViewBag.PaymentLabels ?? "[]");
        const pmData = @Html.Raw(ViewBag.PaymentData ?? "[]");

        new Chart(document.getElementById('chartPayment'), {
            type: 'doughnut',
            data: {
                labels: pmLabels,
                datasets: [{ data: pmData, backgroundColor: pmColors, borderWidth: 3, borderColor: '#fff' }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                cutout: '60%'
            }
        });
    </script>
}
@model DapperBigData.Dtos.MonthlyTargetDtos.GetByIdMonthlyTargetDto
@{
    string[] months = { "", "Ocak", "Şubat", "Mart", "Nisan", "Mayıs", "Haziran", "Temmuz", "Ağustos", "Eylül", "Ekim", "Kasım", "Aralık" };
}

<div class="card">
    <div class="card-hdr">
        <div>
            <div class="card-title">Aylık Hedef</div>
            <div class="card-sub">@months[Model.TargetMonth] @Model.TargetYear</div>
        </div>
        <a asp-controller="MonthlyTarget" asp-action="MonthlyTargetList" class="btn btn-ghost btn-sm">
            Tümünü Gör <i class="fas fa-arrow-right"></i>
        </a>
    </div>
    <div style="display:flex;flex-direction:column;gap:16px">
        <div>
            <div style="display:flex;justify-content:space-between;margin-bottom:8px">
                <span style="font-size:12px;font-weight:600;color:var(--muted)">Ciro Hedefi</span>
                <span style="font-size:12px;font-weight:700">
                    @Model.ActualRevenue.ToString("N0") ₺ / @Model.RevenueTarget.ToString("N0") ₺
                </span>
            </div>
            <div style="background:var(--bg);border-radius:8px;height:10px;overflow:hidden">
                <div style="height:100%;width:@(Math.Min(Model.RevenueAchievementPct, 100))%;background:linear-gradient(90deg,var(--primary),var(--purple));border-radius:8px"></div>
            </div>
            <div style="text-align:right;margin-top:4px;font-size:11px;font-weight:700;color:var(--primary)">
                %@Model.RevenueAchievementPct
            </div>
        </div>
        <div>
            <div style="display:flex;justify-content:space-between;margin-bottom:8px">
                <span style="font-size:12px;font-weight:600;color:var(--muted)">Sipariş Hedefi</span>
                <span style="font-size:12px;font-weight:700">
                    @Model.ActualOrders.ToString("N0") / @Model.OrderTarget.ToString("N0")
                </span>
            </div>
            <div style="background:var(--bg);border-radius:8px;height:10px;overflow:hidden">
                <div style="height:100%;width:@(Math.Min(Model.OrderAchievementPct, 100))%;background:linear-gradient(90deg,var(--success),#16A34A);border-radius:8px"></div>
            </div>
            <div style="text-align:right;margin-top:4px;font-size:11px;font-weight:700;color:var(--success)">
                %@Model.OrderAchievementPct
            </div>
        </div>
    </div>
</div>
@model IEnumerable<dynamic>

<div class="card" style="margin-top:16px">
    <div class="card-hdr">
        <div>
            <div class="card-title">City Sales Map — Turkey</div>
            <div class="card-sub">Şehir bazlı ciro yoğunluğu · Hover ile keşfet</div>
        </div>
        <span class="badge badge-primary">81 Şehir</span>
    </div>
    <div style="position:relative;height:200px;background:var(--bg);border-radius:10px;overflow:hidden">
        <svg width="100%" height="200" viewBox="0 0 560 180" style="position:absolute;opacity:.12">
            <path d="M20,90 Q40,60 80,55 Q120,50 160,60 Q200,70 240,55 Q260,48 290,52 Q330,58 360,50 Q400,42 440,55 Q480,68 530,80 Q550,90 540,110 Q520,130 490,135 Q460,140 420,130 Q380,120 340,125 Q300,130 260,120 Q220,110 180,125 Q140,140 100,130 Q60,120 30,110 Q15,100 20,90 Z" fill="#6366F1" />
        </svg>

        @foreach (var city in Model)
        {
            <div class="map-dot"
                 style="position:absolute;width:@(city.Size)px;height:@(city.Size)px;border-radius:50%;background:rgba(99,102,241,@city.Opacity);border:2px solid #fff;left:@city.Left;top:@city.Top;transform:translate(-50%,-50%);cursor:pointer;transition:transform .2s,box-shadow .2s"
                 data-city="@city.CityName"
                 data-revenue="₺@(((decimal)city.TotalRevenue / 1000000).ToString("N1"))M"
                 data-orders="@(((int)city.TotalOrders).ToString("N0")) sipariş">
            </div>
        }

        <div id="map-tooltip" style="position:absolute;background:#1E293B;color:#fff;padding:6px 10px;border-radius:8px;font-size:11px;font-weight:700;pointer-events:none;display:none;z-index:10;white-space:nowrap;box-shadow:0 4px 12px rgba(0,0,0,.2)">
            <div id="map-tooltip-city"></div>
            <div id="map-tooltip-revenue" style="color:#A5B4FC;font-weight:600;margin-top:2px"></div>
            <div id="map-tooltip-orders" style="color:#94A3B8;font-weight:500;margin-top:1px;font-size:10px"></div>
        </div>

        <div style="position:absolute;bottom:12px;right:14px;display:flex;align-items:center;gap:12px;font-size:10.5px;font-weight:700;color:var(--muted)">
            <span style="display:flex;align-items:center;gap:4px">
                <span style="width:9px;height:9px;border-radius:50%;background:rgba(99,102,241,.9)"></span>Yüksek
            </span>
            <span style="display:flex;align-items:center;gap:4px">
                <span style="width:9px;height:9px;border-radius:50%;background:rgba(99,102,241,.5)"></span>Orta
            </span>
            <span style="display:flex;align-items:center;gap:4px">
                <span style="width:9px;height:9px;border-radius:50%;background:rgba(99,102,241,.3)"></span>Düşük
            </span>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.map-dot').forEach(dot => {
        dot.addEventListener('mouseenter', function () {
            const container = this.closest('div[style*="position:relative"]');
            const containerRect = container.getBoundingClientRect();
            const dotRect = this.getBoundingClientRect();
            const tooltip = document.getElementById('map-tooltip');

            document.getElementById('map-tooltip-city').textContent = this.dataset.city;
            document.getElementById('map-tooltip-revenue').textContent = this.dataset.revenue;
            document.getElementById('map-tooltip-orders').textContent = this.dataset.orders;

            const left = dotRect.left - containerRect.left + dotRect.width / 2;
            const top = dotRect.top - containerRect.top - 55;

            tooltip.style.left = left + 'px';
            tooltip.style.top = top + 'px';
            tooltip.style.transform = 'translateX(-50%)';
            tooltip.style.display = 'block';

            this.style.transform = 'translate(-50%,-50%) scale(1.4)';
            this.style.boxShadow = '0 0 14px rgba(99,102,241,.7)';
        });

        dot.addEventListener('mouseleave', function () {
            document.getElementById('map-tooltip').style.display = 'none';
            this.style.transform = 'translate(-50%,-50%) scale(1)';
            this.style.boxShadow = '';
        });
    });
</script>
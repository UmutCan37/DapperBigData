@model List<DapperBigData.Dtos.CategoryDtos.ResultCategoryDto>

<div class="card">
    <div class="card-hdr">
        <div>
            <div class="card-title">Top Kategoriler</div>
            <div class="card-sub">Ciroya göre ilk 5</div>
        </div>
        <a asp-controller="Category" asp-action="CategoryList" class="btn btn-ghost btn-sm">
            Tümünü Gör <i class="fas fa-arrow-right"></i>
        </a>
    </div>
    <div style="display:flex;flex-direction:column;gap:12px">
        @foreach (var item in Model)
        {
            <div style="display:flex;align-items:center;gap:12px">
                <div style="width:36px;height:36px;border-radius:10px;background:@(item.ColorCode)22;display:flex;align-items:center;justify-content:center;color:@item.ColorCode;flex-shrink:0">
                    <i class="fas @item.IconClass"></i>
                </div>
                <div style="flex:1;min-width:0">
                    <div style="display:flex;justify-content:space-between;margin-bottom:5px">
                        <span style="font-weight:600;font-size:12.5px">@item.CategoryName</span>
                        <span style="font-weight:700;font-size:12.5px">@item.TotalRevenue.ToString("N0") ₺</span>
                    </div>
                    <div style="background:var(--bg);border-radius:4px;height:6px;overflow:hidden">
                        @{
                            var maxRevenue = Model.Max(x => x.TotalRevenue);
                            var pct = maxRevenue > 0 ? (item.TotalRevenue / maxRevenue * 100) : 0;
                        }
                        <div style="height:100%;width:@pct%;background:@item.ColorCode;border-radius:4px"></div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
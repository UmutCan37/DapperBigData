@model List<DapperBigData.Dtos.PaymentMethodDtos.ResultPaymentMethodDto>

<div class="card">
    <div class="card-hdr">
        <div>
            <div class="card-title">Ödeme Yöntemleri</div>
            <div class="card-sub">Dağılım 2024</div>
        </div>
    </div>
    <div class="chart-wrap" style="height:160px">
        <canvas id="chartPayment"></canvas>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:12px">
        @{
            string[] colors = { "#6366F1", "#22C55E", "#F59E0B", "#EF4444" };
            int totalOrders = Model.Sum(x => x.TotalOrders);
        }
        @for (int i = 0; i < Model.Count; i++)
        {
            var item = Model[i];
            var pct = totalOrders > 0 ? (item.TotalOrders * 100 / totalOrders) : 0;
            var color = i < colors.Length ? colors[i] : "#CBD5E1";
            <div style="display:flex;align-items:center;gap:7px">
                <span style="width:9px;height:9px;border-radius:50%;background:@color;flex-shrink:0"></span>
                <span style="font-size:11px;color:var(--muted)">@item.MethodName</span>
                <span style="margin-left:auto;font-size:11.5px;font-weight:700">%@pct</span>
            </div>
        }
    </div>
</div>
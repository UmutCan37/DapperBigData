@model DapperBigData.Dtos.ProductDtos.GetByIdProductDto
@{
    ViewData["Title"] = "Ürün Detay";
}

<div class="page-hdr">
    <div>
        <div class="breadcrumb">Ana Menü / Ürünler / <span>Detay</span></div>
        <div class="page-title">@Model.ProductName</div>
    </div>
    <div class="hdr-actions">
        <a asp-action="UpdateProduct" asp-route-id="@Model.ProductId" class="btn btn-ghost">
            <i class="fas fa-pen"></i> Düzenle
        </a>
        <a asp-action="ProductList" class="btn btn-ghost">
            <i class="fas fa-arrow-left"></i> Geri
        </a>
    </div>
</div>

<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">
    <div class="kpi-card">
        <div class="kpi-icon" style="background:var(--primary-dim);color:var(--primary)">
            <i class="fas fa-cart-shopping"></i>
        </div>
        <div class="kpi-label">Toplam Satış</div>
        <div class="kpi-val">@Model.TotalSold.ToString("N0")</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:var(--success-dim);color:var(--success)">
            <i class="fas fa-turkish-lira-sign"></i>
        </div>
        <div class="kpi-label">Toplam Ciro</div>
        <div class="kpi-val">@Model.TotalRevenue.ToString("N0") ₺</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-icon" style="background:var(--warning-dim);color:var(--warning)">
            <i class="fas fa-boxes-stacked"></i>
        </div>
        <div class="kpi-label">Stok</div>
        <div class="kpi-val">@Model.StockQuantity</div>
    </div>
</div>

<div class="card">
    <div class="card-hdr">
        <div class="card-title">Ürün Bilgileri</div>
        @if (Model.IsActive)
        {
            <span class="badge badge-success">Aktif</span>
        }
        else
        {
            <span class="badge badge-danger">Pasif</span>
        }
    </div>
    <div style="display:flex;flex-direction:column;gap:14px">
        <div style="display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--border)">
            <span style="color:var(--muted);font-weight:600">Ürün ID</span>
            <span style="font-weight:700">#@Model.ProductId</span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--border)">
            <span style="color:var(--muted);font-weight:600">Ürün Adı</span>
            <span style="font-weight:700">@Model.ProductName</span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--border)">
            <span style="color:var(--muted);font-weight:600">SKU</span>
            <code>@Model.Sku</code>
        </div>
        <div style="display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--border)">
            <span style="color:var(--muted);font-weight:600">Kategori</span>
            <span class="badge" style="background:@(Model.CategoryColor)22;color:@Model.CategoryColor">@Model.CategoryName</span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--border)">
            <span style="color:var(--muted);font-weight:600">Birim Fiyat</span>
            <span style="font-weight:700">@Model.UnitPrice.ToString("N2") ₺</span>
        </div>
        <div style="display:flex;justify-content:space-between;padding:12px 0">
            <span style="color:var(--muted);font-weight:600">Eklenme Tarihi</span>
            <span>@Model.CreatedAt.ToString("dd.MM.yyyy")</span>
        </div>
    </div>
</div>
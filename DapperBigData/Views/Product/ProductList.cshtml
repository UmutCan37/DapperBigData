@model List<DapperBigData.Dtos.ProductDtos.ResultProductDto>
@{
    ViewData["Title"] = "Ürünler";
}

<div class="page-hdr">
    <div>
        <div class="breadcrumb">Ana Menü / <span>Ürünler</span></div>
        <div class="page-title">Ürünler</div>
        <div class="page-sub">Toplam @ViewBag.TotalCount kayıt</div>
    </div>
    <div class="hdr-actions">
        <a asp-action="CreateProduct" class="btn btn-primary">
            <i class="fas fa-plus"></i> Yeni Ürün
        </a>
    </div>
</div>

<div class="card">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Ürün Adı</th>
                    <th>SKU</th>
                    <th>Kategori</th>
                    <th>Fiyat</th>
                    <th>Stok</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ProductId</td>
                        <td style="font-weight:600">@item.ProductName</td>
                        <td><code>@item.Sku</code></td>
                        <td>
                            <span class="badge" style="background:@(item.CategoryColor)22;color:@item.CategoryColor">
                                @item.CategoryName
                            </span>
                        </td>
                        <td style="font-weight:700">@item.UnitPrice.ToString("N2") ₺</td>
                        <td>
                            @if (item.StockQuantity < 20)
                            {
                                <span class="badge badge-danger">@item.StockQuantity</span>
                            }
                            else if (item.StockQuantity < 50)
                            {
                                <span class="badge badge-warning">@item.StockQuantity</span>
                            }
                            else
                            {
                                <span class="badge badge-success">@item.StockQuantity</span>
                            }
                        </td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge badge-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Pasif</span>
                            }
                        </td>
                        <td>
                            <div style="display:flex;gap:6px">
                                <a asp-action="ProductDetail" asp-route-id="@item.ProductId" class="btn btn-ghost btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="UpdateProduct" asp-route-id="@item.ProductId" class="btn btn-ghost btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <a asp-action="DeleteProduct" asp-route-id="@item.ProductId" class="btn btn-danger btn-sm"
                                   onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination")
</div>
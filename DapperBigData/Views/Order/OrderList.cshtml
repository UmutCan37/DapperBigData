@model List<DapperBigData.Dtos.OrderDtos.ResultOrderDto>
@{
    ViewData["Title"] = "Siparişler";
}

<div class="page-hdr">
    <div>
        <div class="breadcrumb">Ana Menü / <span>Siparişler</span></div>
        <div class="page-title">Siparişler</div>
        <div class="page-sub">Toplam @ViewBag.TotalCount kayıt</div>
    </div>
    <div class="hdr-actions">
        <a asp-action="CreateOrder" class="btn btn-primary">
            <i class="fas fa-plus"></i> Yeni Sipariş
        </a>
    </div>
</div>

<div class="card">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Sipariş No</th>
                    <th>Müşteri</th>
                    <th>Şehir</th>
                    <th>Ödeme</th>
                    <th>Tarih</th>
                    <th>Tutar</th>
                    <th>Durum</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.OrderId</td>
                        <td><code>@item.OrderNumber</code></td>
                        <td style="font-weight:600">@item.CustomerFullName</td>
                        <td><span class="badge badge-muted">@item.CityName</span></td>
                        <td>
                            <div style="display:flex;align-items:center;gap:6px">
                                <i class="fas @item.PaymentIconClass" style="color:var(--muted)"></i>
                                @item.PaymentMethod
                            </div>
                        </td>
                        <td>@item.OrderDate.ToString("dd.MM.yyyy")</td>
                        <td style="font-weight:700">@item.TotalAmount.ToString("N2") ₺</td>
                        <td>
                            @if (item.OrderStatus == "Completed")
                            {
                                <span class="badge badge-success">Tamamlandı</span>
                            }
                            else if (item.OrderStatus == "Pending")
                            {
                                <span class="badge badge-warning">Beklemede</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">İptal</span>
                            }
                        </td>
                        <td>
                            <div style="display:flex;gap:6px">
                                <a asp-action="OrderDetail" asp-route-id="@item.OrderId" class="btn btn-ghost btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="UpdateOrder" asp-route-id="@item.OrderId" class="btn btn-ghost btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <a asp-action="DeleteOrder" asp-route-id="@item.OrderId" class="btn btn-danger btn-sm"
                                   onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination")
</div>
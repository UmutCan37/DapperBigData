@model List<DapperBigData.Dtos.SystemSettingDtos.ResultSystemSettingDto>
@{
    ViewData["Title"] = "Sistem Ayarları";
}

<div class="page-hdr">
    <div>
        <div class="breadcrumb">Sistem / <span>Ayarlar</span></div>
        <div class="page-title">Sistem Ayarları</div>
        <div class="page-sub">Toplam @ViewBag.TotalCount kayıt</div>
    </div>
    <div class="hdr-actions">
        <a asp-action="CreateSystemSetting" class="btn btn-primary">
            <i class="fas fa-plus"></i> Yeni Ayar
        </a>
    </div>
</div>

<div class="card">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Anahtar</th>
                    <th>Değer</th>
                    <th>Tür</th>
                    <th>Açıklama</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.SettingId</td>
                        <td><code>@item.SettingKey</code></td>
                        <td style="font-weight:600">@item.SettingValue</td>
                        <td>
                            @if (item.IsToggle)
                            {
                                <span class="badge badge-purple">Toggle</span>
                            }
                            else
                            {
                                <span class="badge badge-muted">Input</span>
                            }
                        </td>
                        <td style="color:var(--muted)">@item.Description</td>
                        <td>
                            <div style="display:flex;gap:6px">
                                <a asp-action="SystemSettingDetail" asp-route-id="@item.SettingId" class="btn btn-ghost btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="UpdateSystemSetting" asp-route-id="@item.SettingId" class="btn btn-ghost btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <a asp-action="DeleteSystemSetting" asp-route-id="@item.SettingId" class="btn btn-danger btn-sm"
                                   onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination")
</div>
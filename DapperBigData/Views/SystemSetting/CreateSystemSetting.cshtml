@model DapperBigData.Dtos.SystemSettingDtos.CreateSystemSettingDto
@{
    ViewData["Title"] = "Yeni Ayar";
}

<div class="page-hdr">
    <div>
        <div class="breadcrumb">Sistem / Ayarlar / <span>Yeni Ayar</span></div>
        <div class="page-title">Yeni Ayar</div>
    </div>
    <div class="hdr-actions">
        <a asp-action="SystemSettingList" class="btn btn-ghost">
            <i class="fas fa-arrow-left"></i> Geri
        </a>
    </div>
</div>

<div class="card" style="max-width:600px">
    <form asp-action="CreateSystemSetting" method="post">
        <div style="display:flex;flex-direction:column;gap:16px">
            <div class="form-group">
                <label class="form-label">Anahtar (Key)</label>
                <input asp-for="SettingKey" class="form-control" placeholder="MaintenanceMode" />
            </div>
            <div class="form-group">
                <label class="form-label">Değer (Value)</label>
                <input asp-for="SettingValue" class="form-control" placeholder="true" />
            </div>
            <div class="form-group">
                <label class="form-label">Tür</label>
                <select name="IsToggle" class="form-control">
                    <option value="false">Input (Metin/Sayı)</option>
                    <option value="true">Toggle (Açık/Kapalı)</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Açıklama</label>
                <input asp-for="Description" class="form-control" placeholder="Ayar açıklaması" />
            </div>
            <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:8px">
                <a asp-action="SystemSettingList" class="btn btn-ghost">İptal</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-check"></i> Kaydet
                </button>
            </div>
        </div>
    </form>
</div>
@model DapperBigData.Dtos.CityDtos.CreateCityDto
@{
    ViewData["Title"] = "Yeni Şehir";
}

<div class="page-hdr">
    <div>
        <div class="breadcrumb">Raporlar / Şehirler / <span>Yeni Şehir</span></div>
        <div class="page-title">Yeni Şehir</div>
    </div>
    <div class="hdr-actions">
        <a asp-action="CityList" class="btn btn-ghost">
            <i class="fas fa-arrow-left"></i> Geri
        </a>
    </div>
</div>

<div class="card" style="max-width:600px">
    <form asp-action="CreateCity" method="post">
        <div style="display:flex;flex-direction:column;gap:16px">
            <div class="form-group">
                <label class="form-label">Şehir Adı</label>
                <input asp-for="CityName" class="form-control" placeholder="İstanbul" />
            </div>
            <div class="form-group">
                <label class="form-label">Plaka Kodu</label>
                <input asp-for="PlateCode" class="form-control" placeholder="34" />
            </div>
            <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:8px">
                <a asp-action="CityList" class="btn btn-ghost">İptal</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-check"></i> Kaydet
                </button>
            </div>
        </div>
    </form>
</div>
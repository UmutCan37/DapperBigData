@model List<DapperBigData.Dtos.CityDtos.ResultCityDto>
@{
    ViewData["Title"] = "Şehirler";
}

<div class="page-hdr">
    <div>
        <div class="breadcrumb">Raporlar / <span>Şehirler</span></div>
        <div class="page-title">Şehirler</div>
        <div class="page-sub">Toplam @ViewBag.TotalCount kayıt</div>
    </div>
    <div class="hdr-actions">
        <a asp-action="CreateCity" class="btn btn-primary">
            <i class="fas fa-plus"></i> Yeni Şehir
        </a>
    </div>
</div>

<div class="card">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Şehir Adı</th>
                    <th>Plaka</th>
                    <th>Toplam Sipariş</th>
                    <th>Toplam Ciro</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CityId</td>
                        <td style="font-weight:600">@item.CityName</td>
                        <td><span class="badge badge-muted">@item.PlateCode</span></td>
                        <td>@item.TotalOrders.ToString("N0")</td>
                        <td style="font-weight:700">@item.TotalRevenue.ToString("N2") ₺</td>
                        <td>
                            <div style="display:flex;gap:6px">
                                <a asp-action="CityDetail" asp-route-id="@item.CityId" class="btn btn-ghost btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="UpdateCity" asp-route-id="@item.CityId" class="btn btn-ghost btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <a asp-action="DeleteCity" asp-route-id="@item.CityId" class="btn btn-danger btn-sm"
                                   onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination")
</div>
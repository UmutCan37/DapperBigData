@model List<DapperBigData.Dtos.CategoryDtos.ResultCategoryDto>
@{
    ViewData["Title"] = "Kategoriler";
}

<div class="page-hdr">
    <div>
        <div class="breadcrumb">Ana Menü / <span>Kategoriler</span></div>
        <div class="page-title">Kategoriler</div>
        <div class="page-sub">Toplam @ViewBag.TotalCount kayıt</div>
    </div>
    <div class="hdr-actions">
        <a asp-action="CreateCategory" class="btn btn-primary">
            <i class="fas fa-plus"></i> Yeni Kategori
        </a>
    </div>
</div>

<div class="card">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Kategori Adı</th>
                    <th>İkon</th>
                    <th>Renk</th>
                    <th>Ürün Sayısı</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CategoryId</td>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px">
                                <div style="width:32px;height:32px;border-radius:8px;background:@(item.ColorCode)22;display:flex;align-items:center;justify-content:center;color:@item.ColorCode">
                                    <i class="fas @item.IconClass"></i>
                                </div>
                                <span style="font-weight:600">@item.CategoryName</span>
                            </div>
                        </td>
                        <td><code>@item.IconClass</code></td>
                        <td>
                            <div style="display:flex;align-items:center;gap:8px">
                                <div style="width:16px;height:16px;border-radius:4px;background:@item.ColorCode"></div>
                                @item.ColorCode
                            </div>
                        </td>
                        <td><span class="badge badge-primary">@item.ProductCount ürün</span></td>
                        <td>
                            <div style="display:flex;gap:6px">
                                <a asp-action="CategoryDetail" asp-route-id="@item.CategoryId" class="btn btn-ghost btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="UpdateCategory" asp-route-id="@item.CategoryId" class="btn btn-ghost btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <a asp-action="DeleteCategory" asp-route-id="@item.CategoryId" class="btn btn-danger btn-sm"
                                   onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination")
</div>
@model DapperBigData.Dtos.CategoryDtos.CreateCategoryDto
@{
    ViewData["Title"] = "Yeni Kategori";
}

<div class="page-hdr">
    <div>
        <div class="breadcrumb">Ana Menü / Kategoriler / <span>Yeni Kategori</span></div>
        <div class="page-title">Yeni Kategori</div>
    </div>
    <div class="hdr-actions">
        <a asp-action="CategoryList" class="btn btn-ghost">
            <i class="fas fa-arrow-left"></i> Geri
        </a>
    </div>
</div>

<div class="card" style="max-width:600px">
    <form asp-action="CreateCategory" method="post">
        <div style="display:flex;flex-direction:column;gap:16px">
            <div class="form-group">
                <label class="form-label">Kategori Adı</label>
                <input asp-for="CategoryName" class="form-control" placeholder="Elektronik" />
            </div>
            <div class="form-group">
                <label class="form-label">İkon Class (Font Awesome)</label>
                <input asp-for="IconClass" class="form-control" placeholder="fa-desktop" />
            </div>
            <div class="form-group">
                <label class="form-label">Renk Kodu</label>
                <input asp-for="ColorCode" class="form-control" placeholder="#6366F1" />
            </div>
            <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:8px">
                <a asp-action="CategoryList" class="btn btn-ghost">İptal</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-check"></i> Kaydet
                </button>
            </div>
        </div>
    </form>
</div>
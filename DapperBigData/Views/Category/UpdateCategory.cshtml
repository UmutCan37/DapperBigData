@model DapperBigData.Dtos.CategoryDtos.GetByIdCategoryDto
@{
    ViewData["Title"] = "Kategori Düzenle";
}

<div class="page-hdr">
    <div>
        <div class="breadcrumb">Ana Menü / Kategoriler / <span>Düzenle</span></div>
        <div class="page-title">Kategori Düzenle</div>
    </div>
    <div class="hdr-actions">
        <a asp-action="CategoryList" class="btn btn-ghost">
            <i class="fas fa-arrow-left"></i> Geri
        </a>
    </div>
</div>

<div class="card" style="max-width:600px">
    <form asp-action="UpdateCategory" method="post">
        <input type="hidden" name="CategoryId" value="@Model.CategoryId" />
        <div style="display:flex;flex-direction:column;gap:16px">
            <div class="form-group">
                <label class="form-label">Kategori Adı</label>
                <input type="text" name="CategoryName" value="@Model.CategoryName" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">İkon Class (Font Awesome)</label>
                <input type="text" name="IconClass" value="@Model.IconClass" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">Renk Kodu</label>
                <input type="text" name="ColorCode" value="@Model.ColorCode" class="form-control" />
            </div>
            <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:8px">
                <a asp-action="CategoryList" class="btn btn-ghost">İptal</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-check"></i> Güncelle
                </button>
            </div>
        </div>
    </form>
</div>
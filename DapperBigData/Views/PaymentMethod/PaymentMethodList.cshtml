@model List<DapperBigData.Dtos.PaymentMethodDtos.ResultPaymentMethodDto>
@{
    ViewData["Title"] = "Ödeme Yöntemleri";
}

<div class="page-hdr">
    <div>
        <div class="breadcrumb">Raporlar / <span>Ödeme Yöntemleri</span></div>
        <div class="page-title">Ödeme Yöntemleri</div>
        <div class="page-sub">Toplam @ViewBag.TotalCount kayıt</div>
    </div>
    <div class="hdr-actions">
        <a asp-action="CreatePaymentMethod" class="btn btn-primary">
            <i class="fas fa-plus"></i> Yeni Ödeme Yöntemi
        </a>
    </div>
</div>

<div class="card">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Yöntem Adı</th>
                    <th>İkon</th>
                    <th>Toplam Sipariş</th>
                    <th>Toplam Ciro</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.PaymentMethodId</td>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px">
                                <div style="width:32px;height:32px;border-radius:8px;background:var(--primary-dim);display:flex;align-items:center;justify-content:center;color:var(--primary)">
                                    <i class="fas @item.IconClass"></i>
                                </div>
                                <span style="font-weight:600">@item.MethodName</span>
                            </div>
                        </td>
                        <td><code>@item.IconClass</code></td>
                        <td>@item.TotalOrders.ToString("N0")</td>
                        <td style="font-weight:700">@item.TotalRevenue.ToString("N2") ₺</td>
                        <td>
                            <div style="display:flex;gap:6px">
                                <a asp-action="PaymentMethodDetail" asp-route-id="@item.PaymentMethodId" class="btn btn-ghost btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="UpdatePaymentMethod" asp-route-id="@item.PaymentMethodId" class="btn btn-ghost btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <a asp-action="DeletePaymentMethod" asp-route-id="@item.PaymentMethodId" class="btn btn-danger btn-sm"
                                   onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @await Html.PartialAsync("_Pagination")
</div>
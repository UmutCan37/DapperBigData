@model DapperBigData.Dtos.PaymentMethodDtos.GetByIdPaymentMethodDto
@{
    ViewData["Title"] = "Ödeme Yöntemi Düzenle";
}

<div class="page-hdr">
    <div>
        <div class="breadcrumb">Raporlar / Ödeme Yöntemleri / <span>Düzenle</span></div>
        <div class="page-title">Ödeme Yöntemi Düzenle</div>
    </div>
    <div class="hdr-actions">
        <a asp-action="PaymentMethodList" class="btn btn-ghost">
            <i class="fas fa-arrow-left"></i> Geri
        </a>
    </div>
</div>

<div class="card" style="max-width:600px">
    <form asp-action="UpdatePaymentMethod" method="post">
        <input type="hidden" name="PaymentMethodId" value="@Model.PaymentMethodId" />
        <div style="display:flex;flex-direction:column;gap:16px">
            <div class="form-group">
                <label class="form-label">Yöntem Adı</label>
                <input type="text" name="MethodName" value="@Model.MethodName" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">İkon Class (Font Awesome)</label>
                <input type="text" name="IconClass" value="@Model.IconClass" class="form-control" />
            </div>
            <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:8px">
                <a asp-action="PaymentMethodList" class="btn btn-ghost">İptal</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-check"></i> Güncelle
                </button>
            </div>
        </div>
    </form>
</div>